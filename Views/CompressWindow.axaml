<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SevenZipExt.ViewModels"
        xmlns:m="using:SevenZipExt.Models"
        x:Class="SevenZipExt.Views.CompressWindow"
        x:DataType="vm:CompressWindowViewModel"
        Title="添加到压缩包"
        Width="660" MinWidth="560"
        SizeToContent="Height"
        CanResize="True"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Window.Styles>
        <Style Selector="TextBlock.lbl">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="88"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="Border.group">
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
        <Style Selector="TextBlock.val">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Styles>

    <DockPanel LastChildFill="True">

        <!-- Bottom Buttons -->
        <Border DockPanel.Dock="Bottom" Background="#E8E8E8" Padding="8,6">
            <StackPanel Spacing="4">
                <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#333"
                           TextWrapping="Wrap" MaxWidth="620"
                           IsVisible="{Binding ProgressText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                    <Button Content="确定(_O)" Width="80" IsEnabled="{Binding !IsRunning}"
                            Command="{Binding CompressCommand}" IsDefault="True"/>
                    <Button Content="取消(_C)" Width="80"
                            Command="{Binding CancelCommand}" IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10,8" Spacing="5">

                <Border Classes="group" Margin="0,0,0,2">
                    <StackPanel Spacing="6">
                        <TextBlock Text="待压缩文件或文件夹" FontWeight="SemiBold" FontSize="12"/>

                        <ListBox ItemsSource="{Binding SourceItems}"
                                 SelectionMode="Multiple,Toggle"
                                 Height="96"
                                 Background="White"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 SelectionChanged="OnSourceSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <TextBlock Text="{Binding .}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="添加文件" Margin="0,0,6,0" Padding="10,3"
                                    Command="{Binding AddSourceFilesCommand}"/>
                            <Button Content="添加文件夹" Margin="0,0,6,0" Padding="10,3"
                                    Command="{Binding AddSourceFoldersCommand}"/>
                            <Button Content="移除选中" Padding="10,3"
                                    Command="{Binding RemoveSourceItemsCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Save file path row -->
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="保存文件路径(A):" Classes="lbl" Width="88"/>
                    <TextBox Text="{Binding ArchivePath}" Width="510"/>
                    <Button Content="..." Width="34" Command="{Binding BrowseArchiveCommand}" ToolTip.Tip="选择保存目录"/>
                </StackPanel>

                <!-- Two-column settings -->
                <Grid ColumnDefinitions="*,*" Margin="0,2">

                    <!-- ===== Left column ===== -->
                    <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,6,0">

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="压缩格式(F):" Classes="lbl"/>
                            <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.Formats}"
                                      SelectedItem="{Binding SelectedFormat}" Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="压缩等级(L):" Classes="lbl"/>
                            <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.Levels}"
                                      SelectedItem="{Binding SelectedLevel}" Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="压缩方法(M):" Classes="lbl"/>
                            <ComboBox ItemsSource="{Binding Methods}"
                                      SelectedItem="{Binding SelectedMethod}"
                                      IsEnabled="{Binding IsMethodEnabled}"
                                      Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="字典大小(D):" Classes="lbl"/>
                            <ComboBox ItemsSource="{Binding DictionarySizes}"
                                      SelectedItem="{Binding SelectedDictionarySize}"
                                      IsEnabled="{Binding IsDictionaryEnabled}"
                                      Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="单词大小(W):" Classes="lbl"/>
                            <ComboBox ItemsSource="{Binding WordSizes}"
                                      SelectedItem="{Binding SelectedWordSize}"
                                      IsEnabled="{Binding IsWordSizeEnabled}"
                                      Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="固实大小(S):" Classes="lbl"/>
                            <ComboBox ItemsSource="{Binding SolidBlockSizes}"
                                      SelectedItem="{Binding SelectedSolidBlockSize}"
                                      IsEnabled="{Binding IsSolidEnabled}"
                                      Width="168"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="CPU 线程数:" Classes="lbl"/>
                            <ComboBox ItemsSource="{Binding ThreadOptions}"
                                      SelectedItem="{Binding SelectedThreads}"
                                      IsEnabled="{Binding IsThreadCountEnabled}"
                                      Width="100"/>
                            <TextBlock Text="{x:Static vm:CompressWindowViewModel.SystemThreadCountDisplay}"
                                       Classes="val" Foreground="#555"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="压缩内存:" Classes="lbl"/>
                            <TextBlock Text="{Binding MemoryCompress}" Classes="val"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="解压内存:" Classes="lbl"/>
                            <TextBlock Text="{Binding MemoryDecompress}" Classes="val"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="88,*" IsEnabled="{Binding IsVolumeEnabled}">
                            <TextBlock Text="分卷大小(V):" Classes="lbl" Grid.Column="0"/>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <WrapPanel Orientation="Horizontal">
                                    <CheckBox Content="启用"
                                              IsChecked="{Binding IsVolumeSplitEnabled}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0"/>
                                    <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.VolumeModes}"
                                              SelectedItem="{Binding SelectedVolumeMode}"
                                              IsEnabled="{Binding IsVolumeSplitEnabled}"
                                              Width="72"/>
                                </WrapPanel>
                                <ComboBox ItemsSource="{Binding VolumePresets}"
                                          SelectedItem="{Binding SelectedVolumePreset}"
                                          IsVisible="{Binding IsVolumePresetMode}"
                                          IsEnabled="{Binding IsVolumeSplitEnabled}"
                                          Width="168"/>
                                    <WrapPanel Orientation="Horizontal"
                                           IsVisible="{Binding IsVolumeCustomMode}">
                                    <TextBox Text="{Binding VolumeCustomSize}" Width="104" Watermark="数值"
                                           IsEnabled="{Binding IsVolumeSplitEnabled}"
                                           Margin="0,0,6,0"/>
                                    <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.VolumeUnits}"
                                              SelectedItem="{Binding SelectedVolumeUnit}"
                                              IsEnabled="{Binding IsVolumeSplitEnabled}"
                                              Width="72"/>
                                </WrapPanel>
                                <TextBlock Text="默认不分卷，启用后再选择预设或手动输入" FontSize="11" Foreground="#666"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="参数(P):" Classes="lbl"/>
                            <TextBox Text="{Binding AdditionalParams}" Width="168" Watermark="额外参数"/>
                        </StackPanel>

                    </StackPanel>

                    <!-- ===== Right column ===== -->
                    <StackPanel Grid.Column="1" Spacing="4" Margin="6,0,0,0">

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="更新方式(U):" Classes="lbl"/>
                            <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.UpdateMethods}"
                                      SelectedItem="{Binding UpdateMethod}" Width="175"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="路径模式:" Classes="lbl"/>
                            <ComboBox ItemsSource="{x:Static vm:CompressWindowViewModel.PathModes}"
                                      SelectedItem="{Binding PathMode}" Width="175"/>
                        </StackPanel>

                        <!-- Options border -->
                        <Border Classes="group">
                            <StackPanel Spacing="4">
                                <TextBlock Text="选项" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"/>
                                <CheckBox Content="创建自解压程序(_X)"
                                          IsChecked="{Binding CreateSfx}"
                                          IsEnabled="{Binding IsSfxEnabled}"/>
                                <CheckBox Content="压缩共享文件" IsChecked="{Binding CompressSharedFiles}"/>
                                <CheckBox Content="操作完成后删除源文件" IsChecked="{Binding DeleteAfterCompress}"/>
                            </StackPanel>
                        </Border>

                        <!-- Encryption border -->
                        <Border Classes="group" IsEnabled="{Binding IsEncryptionEnabled}">
                            <StackPanel Spacing="5">
                                <TextBlock Text="加密" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,2"/>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="输入密码:" Width="68" Classes="val"/>
                                    <TextBox x:Name="PasswordBox"
                                             Text="{Binding Password}" Width="148"
                                             PasswordChar="{Binding PasswordMaskChar}"
                                             UseLayoutRounding="True"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="重新输入:" Width="68" Classes="val"/>
                                    <TextBox x:Name="PasswordConfirmBox"
                                             Text="{Binding PasswordConfirm}" Width="148"
                                             PasswordChar="{Binding PasswordMaskChar}"/>
                                </StackPanel>

                                <CheckBox Content="显示密码(_S)" IsChecked="{Binding ShowPassword}"/>

                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="加密算法:" Width="68" Classes="val"/>
                                    <ComboBox ItemsSource="{Binding EncryptionMethodOptions}"
                                              SelectedItem="{Binding SelectedEncryption}" Width="148"/>
                                </StackPanel>

                                <CheckBox Content="加密文件名(_N)"
                                          IsChecked="{Binding EncryptFileNames}"
                                          IsEnabled="{Binding IsEncryptFileNamesEnabled}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- ==================== EXCLUSION SECTION ==================== -->
                <Border BorderBrush="#CC3333" BorderThickness="2" CornerRadius="5"
                        Padding="10,8" Margin="0,8,0,0" Background="#FFF8F8">
                    <StackPanel Spacing="6">

                        <TextBlock Text="排除文件或文件夹" FontWeight="Bold" FontSize="13"
                                   Foreground="#CC2222"/>

                        <!-- Exclusion list -->
                        <ListBox x:Name="ExclusionListBox"
                                 ItemsSource="{Binding Exclusions}"
                                 SelectionMode="Multiple,Toggle"
                                 Height="120"
                                 Background="White"
                                 BorderBrush="#CCCCCC"
                                 BorderThickness="1"
                                 SelectionChanged="OnExclusionSelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="m:ExclusionItem">
                                    <Grid ColumnDefinitions="26,*,Auto">
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayIcon}"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Path}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{Binding FullFlag}"
                                                   FontSize="10" Foreground="#888"
                                                   VerticalAlignment="Center" Margin="8,0,4,0"
                                                   FontFamily="Consolas,Courier New,monospace"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Exclusion buttons -->
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="添加文件" Margin="0,0,6,4" Padding="8,3"
                                    Command="{Binding AddExclusionFilesCommand}"/>
                            <Button Content="添加文件夹" Margin="0,0,6,4" Padding="8,3"
                                    Command="{Binding AddExclusionFolderCommand}"/>
                            <Button Content="移除选中" Margin="0,0,0,4" Padding="8,3"
                                    Foreground="#CC2222"
                                    Command="{Binding RemoveExclusionsCommand}"/>
                        </WrapPanel>

                        <!-- Pattern input row -->
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox Text="{Binding PatternInput}" Width="280"
                                     Watermark="输入通配符模式，如 *.log 或 node_modules"/>
                            <Button Content="添加模式" Padding="8,3"
                                    Command="{Binding AddExclusionPatternCommand}"/>
                        </StackPanel>

                        <!-- Command preview -->
                        <Expander Header="命令行预览 (点击展开)" IsExpanded="False" Margin="0,2,0,0">
                            <Border Background="#1E1E1E" CornerRadius="3" Padding="8,6" Margin="0,4,0,0">
                                <TextBlock x:Name="CommandPreview"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="#DCDCAA" Margin="2"/>
                            </Border>
                        </Expander>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
