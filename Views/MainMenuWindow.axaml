<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SevenZipExt.Views.MainMenuWindow"
        Title="7ZipExt - 7-Zip 增强工具"
        Width="380" SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <StackPanel Margin="20,16" Spacing="10">

        <TextBlock Text="7ZipExt" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="7-Zip 增强工具 - 支持压缩时排除文件夹/文件"
                   FontSize="11" Foreground="#666" TextWrapping="Wrap"
                   HorizontalAlignment="Center" TextAlignment="Center"/>

        <Separator Margin="0,4"/>

        <Button x:Name="CompressBtn" Content="📦  压缩文件..." HorizontalAlignment="Stretch"
                Padding="12,8" FontSize="13"/>

        <Button x:Name="ExtractBtn" Content="📂  解压文件..." HorizontalAlignment="Stretch"
                Padding="12,8" FontSize="13"/>

        <Separator Margin="0,4"/>

        <!-- Settings -->
        <Border BorderBrush="#AAA" BorderThickness="1" CornerRadius="4" Padding="12,10">
            <StackPanel Spacing="6">
                <TextBlock Text="设置" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="7-Zip 路径:" VerticalAlignment="Center" Width="80"/>
                    <TextBox x:Name="SevenZipPathBox" FontSize="11" Width="210"/>
                    <Button x:Name="BrowseSevenZipBtn" Content="..." Width="32"/>
                </StackPanel>
                <Button x:Name="SaveSettingsBtn" Content="保存设置" HorizontalAlignment="Right"/>
            </StackPanel>
        </Border>

        <!-- Context menu registration -->
        <Border BorderBrush="#AAA" BorderThickness="1" CornerRadius="4" Padding="12,10">
            <StackPanel Spacing="6">
                <TextBlock Text="右键菜单集成" FontWeight="SemiBold"/>
                <TextBlock x:Name="ContextMenuStatus" FontSize="11" Foreground="#555"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button x:Name="RegisterBtn" Content="注册右键菜单" Padding="8,4"/>
                    <Button x:Name="UnregisterBtn" Content="卸载右键菜单" Padding="8,4"/>
                </StackPanel>
                <TextBlock x:Name="RegStatusText" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <TextBlock Text="使用说明: 右键文件或文件夹 → 7ZipExt → 压缩/解压"
                   FontSize="10" Foreground="#888" TextWrapping="Wrap"/>

    </StackPanel>
</Window>
